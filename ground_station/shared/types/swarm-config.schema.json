{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pixhawkrasppi.local/schemas/swarm-config.schema.json",
  "title": "Swarm Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["swarm_id", "enabled", "self_drone_id", "role", "transport", "peers", "broadcast", "fusion", "safety"],
  "properties": {
    "swarm_id": {
      "type": "string",
      "minLength": 1
    },
    "enabled": {
      "type": "boolean"
    },
    "self_drone_id": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "enum": ["leader", "follower", "relay", "observer", "anchor"]
    },
    "transport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "endpoint"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["http", "websocket", "ipc", "udp", "mavlink", "ble", "native"]
        },
        "endpoint": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string"
        },
        "channel": {
          "type": "string"
        }
      }
    },
    "peers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["drone_id", "role", "transport"],
        "properties": {
          "drone_id": {
            "type": "string",
            "minLength": 1
          },
          "callsign": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": ["leader", "follower", "relay", "observer", "anchor"]
          },
          "transport": {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "endpoint"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["http", "websocket", "ipc", "udp", "mavlink", "ble", "native"]
              },
              "endpoint": {
                "type": "string",
                "minLength": 1
              },
              "path": {
                "type": "string"
              },
              "channel": {
                "type": "string"
              }
            }
          },
          "trust": {
            "type": "string",
            "enum": ["primary", "trusted", "normal", "degraded"]
          },
          "max_age_seconds": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "max_horizontal_error_m": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "max_vertical_error_m": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "requires_rtk": {
            "type": "boolean"
          }
        }
      }
    },
    "broadcast": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "rate_hz",
        "include_location",
        "include_velocity",
        "include_quality",
        "include_vehicle_state",
        "include_alerts"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "rate_hz": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 20
        },
        "include_location": {
          "type": "boolean"
        },
        "include_velocity": {
          "type": "boolean"
        },
        "include_quality": {
          "type": "boolean"
        },
        "include_vehicle_state": {
          "type": "boolean"
        },
        "include_alerts": {
          "type": "boolean"
        }
      }
    },
    "fusion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "min_peer_count",
        "max_peer_age_seconds",
        "require_reference_node",
        "use_peer_velocity",
        "weights"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["none", "separation_only", "weighted_gnss", "relative_pose"]
        },
        "min_peer_count": {
          "type": "integer",
          "minimum": 0
        },
        "max_peer_age_seconds": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "require_reference_node": {
          "type": "boolean"
        },
        "reference_node_id": {
          "type": "string"
        },
        "use_peer_velocity": {
          "type": "boolean"
        },
        "weights": {
          "type": "object",
          "additionalProperties": false,
          "required": ["self_position", "peer_position", "peer_velocity", "heading", "quality"],
          "properties": {
            "self_position": {
              "type": "number",
              "minimum": 0
            },
            "peer_position": {
              "type": "number",
              "minimum": 0
            },
            "peer_velocity": {
              "type": "number",
              "minimum": 0
            },
            "heading": {
              "type": "number",
              "minimum": 0
            },
            "quality": {
              "type": "number",
              "minimum": 0
            }
          }
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "min_horizontal_separation_m",
        "min_vertical_separation_m",
        "warn_distance_m",
        "critical_distance_m",
        "hold_on_loss",
        "hold_timeout_seconds"
      ],
      "properties": {
        "min_horizontal_separation_m": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "min_vertical_separation_m": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "warn_distance_m": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "critical_distance_m": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "hold_on_loss": {
          "type": "boolean"
        },
        "hold_timeout_seconds": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    }
  }
}
