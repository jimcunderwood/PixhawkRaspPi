{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pixhawkrasppi.local/schemas/fleet-config.schema.json",
  "title": "Fleet Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["fleet_id", "drones"],
  "properties": {
    "fleet_id": {
      "type": "string",
      "minLength": 1
    },
    "default_transport": {
      "type": "string",
      "enum": ["http", "websocket", "ipc", "udp", "mavlink", "ble", "native"]
    },
    "drones": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["drone_id", "transport"],
        "properties": {
          "drone_id": {
            "type": "string",
            "minLength": 1
          },
          "callsign": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "transport": {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "endpoint"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["http", "websocket", "ipc", "udp", "mavlink", "ble", "native"]
              },
              "endpoint": {
                "type": "string",
                "minLength": 1
              },
              "api_key": {
                "type": "string"
              },
              "control_token": {
                "type": "string"
              },
              "path": {
                "type": "string"
              },
              "channel": {
                "type": "string"
              }
            }
          },
          "endpoints": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "capabilities": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "status": {
            "type": "string"
          },
          "last_heartbeat": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "device_profiles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["profile_id", "runtime", "preferred_transports"],
        "properties": {
          "profile_id": {
            "type": "string",
            "minLength": 1
          },
          "runtime": {
            "type": "string",
            "enum": ["web", "desktop", "mobile", "embedded"]
          },
          "preferred_transports": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": ["http", "websocket", "ipc", "udp", "mavlink", "ble", "native"]
            }
          }
        }
      }
    }
  }
}
