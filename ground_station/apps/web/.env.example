# Ground-station runtime config. Include the protocol; do not use a bare IP.
# Local companion: COMPANION_BASE_URL=http://localhost:8000
# LAN companion:   COMPANION_BASE_URL=http://192.168.1.140:8000
COMPANION_BASE_URL=http://192.168.1.140:8000

# Copy this from the companion machine's API_KEY setting during install.
# It becomes the default admin password and the default drone Api Key.
API_KEY=replace-with-companion-api-key
