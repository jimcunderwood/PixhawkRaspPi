# MAVLink Connection Configuration
MAVLINK_PORT=/dev/ttyAMA0
MAVLINK_BAUDRATE=57600
MAVLINK_TIMEOUT=30
# For UDP: use MAVLINK_UDP_IP and MAVLINK_UDP_PORT instead
# MAVLINK_UDP_IP=127.0.0.1
# MAVLINK_UDP_PORT=14550

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=False

# Payload Hardware Pins (GPIO)
SPRAY_PUMP_PIN=17
CAMERA_ENABLED=True
CAMERA_PORT=0
FLOW_SENSOR_PIN=27
FLOW_SENSOR_ENABLED=True

# Mission Configuration
MAX_WAYPOINTS=100
MIN_ALTITUDE=5
MAX_ALTITUDE=120
DEFAULT_AIRSPEED=5
LOITER_RADIUS=50

# Telemetry Configuration
TELEMETRY_UPDATE_INTERVAL=0.5
TELEMETRY_HISTORY_SIZE=3600
GPS_TIMEOUT=10

# Application Configuration
ENVIRONMENT=production
LOG_LEVEL=INFO
