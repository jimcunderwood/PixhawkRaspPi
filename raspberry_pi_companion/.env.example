# MAVLink Connection Configuration
MAVLINK_CONNECTION_TYPE=serial
MAVLINK_PORT=/dev/serial0
MAVLINK_BAUDRATE=57600
MAVLINK_TIMEOUT=30

# For UDP SITL on the same Pi:
# MAVLINK_CONNECTION_TYPE=udp
# MAVLINK_UDP_DIRECTION=in
# MAVLINK_UDP_IP=0.0.0.0
# MAVLINK_UDP_PORT=5760

# For remote SITL on another host:
# MAVLINK_CONNECTION_TYPE=udp
# MAVLINK_UDP_DIRECTION=out
# MAVLINK_UDP_IP=192.168.1.40
# MAVLINK_UDP_PORT=5760

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=False
API_AUTH_ENABLED=True
API_KEY=replace-with-a-long-random-token
API_KEY_ROLE=admin
# Optional comma-separated role:key entries. Roles: viewer, operator, admin, maintenance.
# API_KEY_ROLES=viewer:viewer-token,operator:operator-token,maintenance:maintenance-token,admin:admin-token
SAFETY_GATES_ENABLED=True
COMMAND_AUTHORITY_ENABLED=True
COMMAND_AUTHORITY_LEASE_SECONDS=30
IDEMPOTENCY_TTL_SECONDS=300
TELEMETRY_FRESHNESS_ENABLED=True
TELEMETRY_STALE_SECONDS=3
PAYLOAD_STALE_SECONDS=3
AUDIT_LOG_FILE=/var/lib/drone-companion/audit/events.jsonl
# Rotate the audit log when it grows past this size.
# 5 MiB is a reasonable default for a Pi, but you can lower it if storage is tight.
AUDIT_LOG_MAX_BYTES=5242880
# Number of rotated audit files to keep alongside the active log.
AUDIT_LOG_BACKUP_COUNT=5
CONFIG_DATABASE_FILE=/var/lib/drone-companion/config/profiles.sqlite3
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Payload Hardware Pins (GPIO)
SPRAY_PUMP_PIN=17
CAMERA_ENABLED=True
CAMERA_PORT=0
CAMERA_TRIGGER_ENABLED=False
CAMERA_TRIGGER_PIN=22
# Fractional milliseconds are allowed, e.g. 0.5 for 0.5 ms.
CAMERA_TRIGGER_PULSE_MS=100
APP_DATA_DIRECTORY=/var/lib/drone-companion
PHOTO_DIRECTORY=/var/lib/drone-companion/photos
SPRAY_SESSION_DIRECTORY=/var/lib/drone-companion/spray-sessions
MISSION_FILE=/var/lib/drone-companion/missions/mission.json
FLOW_SENSOR_PIN=27
FLOW_SENSOR_ENABLED=True
FLOW_SENSOR_PULSES_PER_LITER=450

# Pressure sensor: SOURCE=adc for MCP3008-style ADC, or gpio for threshold switch
PRESSURE_SENSOR_ENABLED=False
PRESSURE_SENSOR_SOURCE=adc
PRESSURE_SENSOR_PIN=
PRESSURE_SENSOR_ADC_CHANNEL=0
PRESSURE_SENSOR_MIN_VOLTAGE=0.5
PRESSURE_SENSOR_MAX_VOLTAGE=4.5
PRESSURE_SENSOR_MIN_PSI=0
PRESSURE_SENSOR_MAX_PSI=150

# Tank level sensor: SOURCE=adc for level sender, or gpio for low-level switch
TANK_LEVEL_SENSOR_ENABLED=False
TANK_LEVEL_SENSOR_SOURCE=adc
TANK_LEVEL_SENSOR_PIN=
TANK_LEVEL_SENSOR_ADC_CHANNEL=1
TANK_LEVEL_SENSOR_MIN_VOLTAGE=0.5
TANK_LEVEL_SENSOR_MAX_VOLTAGE=4.5
TANK_CAPACITY_LITERS=10
TANK_MIN_LEVEL_PERCENT=10

# RTK/PPK configuration. These typically use Pixhawk/GNSS serial links, not GPIO.
RTK_ENABLED=False
RTK_CORRECTION_PORT=/dev/ttyUSB0
RTK_CORRECTION_BAUDRATE=115200
PPK_ENABLED=False
PPK_LOG_DIRECTORY=/var/lib/drone-companion/ppk
SPRAY_APPLICATION_RECORD_DIRECTORY=/var/lib/drone-companion/application-records

# Terrain following uses Pixhawk MAVLink rangefinder/terrain data when available.
# No Raspberry Pi GPIO pin is needed for Pixhawk-mounted rangefinders.
# Mapping used by the companion app:
#   RNGFND1 / DISTANCE_SENSOR id=0 -> terrain following
#   RNGFND2 / DISTANCE_SENSOR id=1 -> obstacle avoidance
TERRAIN_FOLLOWING_ENABLED=False
TERRAIN_SENSOR_SOURCE=rangefinder
TERRAIN_SENSOR_PIN=
TERRAIN_MIN_AGL_METERS=2
TERRAIN_MAX_AGL_METERS=120
TERRAIN_TARGET_AGL_METERS=
TERRAIN_USE_RANGEFINDER_FOR_WAYPOINTS=True
TERRAIN_RTL_ENABLED=False
TERRAIN_SPACING_METERS=

# Mission Configuration
MAX_WAYPOINTS=100
MIN_ALTITUDE=5
MAX_ALTITUDE=120
DEFAULT_AIRSPEED=5
LOITER_RADIUS=50

# Obstacle avoidance can read from Pixhawk MAVLink, a GPIO pin, or ROS hooks.
# Default mapping:
#   RNGFND1 / DISTANCE_SENSOR id=0 -> terrain following
#   RNGFND2 / DISTANCE_SENSOR id=1 -> forward obstacle sensor
# Modes: simple, bendy_ruler, disabled
OBSTACLE_AVOIDANCE_ENABLED=False
OBSTACLE_AVOIDANCE_MODE=simple
OBSTACLE_AVOIDANCE_MARGIN_METERS=2
OBSTACLE_AVOIDANCE_LOOKAHEAD_METERS=5
OBSTACLE_AVOIDANCE_BACKUP_SPEED_MPS=0
OBSTACLE_AVOIDANCE_MIN_ALTITUDE_METERS=0
OBSTACLE_AVOIDANCE_PROXIMITY_TYPE=4
OBSTACLE_AVOIDANCE_BEHAVIOR=slide
OBSTACLE_AVOIDANCE_BENDY_RULER_TYPE=horizontal
OBSTACLE_DATABASE_SIZE=
OBSTACLE_AVOIDANCE_SENSOR_SOURCE=mavlink
# valid values: mavlink, gpio, ros
OBSTACLE_AVOIDANCE_SENSOR_COVERAGE_MODE=forward
# valid values: forward, 360
OBSTACLE_AVOIDANCE_SENSOR_MAVLINK_ID=1
OBSTACLE_AVOIDANCE_SENSOR_GPIO_PIN=
OBSTACLE_AVOIDANCE_SENSOR_GPIO_ACTIVE_LOW=True
OBSTACLE_AVOIDANCE_SENSOR_ROS_ENABLED=False
OBSTACLE_AVOIDANCE_SENSOR_ROS_BACKEND=mavros
OBSTACLE_AVOIDANCE_SENSOR_ROS_TOPIC=
OBSTACLE_AVOIDANCE_SENSOR_ROS_FRAME_ID=
OBSTACLE_AVOIDANCE_SENSOR_ROS_MESSAGE_TYPE=std_msgs/Float32

# Terrain following stays on the Pixhawk, with optional ROS/MAVROS hooks.
TERRAIN_ROS_BRIDGE_ENABLED=False
TERRAIN_ROS_BACKEND=mavros
TERRAIN_ROS_TOPIC=
TERRAIN_MAVROS_TOPIC=
TERRAIN_ROS_FRAME_ID=

# Mapping / photogrammetry
SURVEY_FRONT_OVERLAP=0.70
SURVEY_SIDE_OVERLAP=0.80
SURVEY_TARGET_GSD_CM=2.5
SURVEY_DEFAULT_ALTITUDE_M=60
SURVEY_DEFAULT_HEADING_DEG=0
SURVEY_FLIGHT_SPEED_MPS=5
SURVEY_TERRAIN_AWARE=False
SURVEY_TERRAIN_CLEARANCE_M=5
SURVEY_BORDER_MARGIN_M=0
CAMERA_SENSOR_WIDTH_MM=13.2
CAMERA_SENSOR_HEIGHT_MM=8.8
CAMERA_IMAGE_WIDTH_PX=4000
CAMERA_IMAGE_HEIGHT_PX=3000
CAMERA_FOCAL_LENGTH_MM=8.8
NDVI_ENABLED=False
NDVI_RED_BAND_INDEX=0
NDVI_NIR_BAND_INDEX=1
ORTHOMOSAIC_PREVIEW_MAX_COLUMNS=4
ORTHOMOSAIC_PREVIEW_TILE_SCALE=0.2
LIDAR_ENABLED=False
LIDAR_TOPIC=
LIDAR_FRAME_ID=base_link

# Telemetry Configuration
TELEMETRY_UPDATE_INTERVAL=0.5
TELEMETRY_HISTORY_SIZE=3600
GPS_TIMEOUT=10

# Safety, geofencing, and compliance
SAFETY_STATE_FILE=/var/lib/drone-companion/safety/state.json
AUTONOMOUS_FAILSAFE_ENABLED=True
ALTITUDE_HARD_MIN_M=0
ALTITUDE_SOFT_MIN_M=2
ALTITUDE_SOFT_MAX_M=110
ALTITUDE_HARD_MAX_M=120
DYNAMIC_GEOFENCE_SPEED_THRESHOLD_MPS=8
DYNAMIC_GEOFENCE_SOFT_CEILING_REDUCTION_M_PER_MPS=1.5
LOST_LINK_WARN_SECONDS=2
LOST_LINK_RTL_SECONDS=5
LOST_LINK_LAND_SECONDS=10
LOW_BATTERY_WARN_PERCENT=30
LOW_BATTERY_RTL_PERCENT=20
LOW_BATTERY_LAND_PERCENT=10
GPS_LOSS_WARN_SECONDS=2
GPS_LOSS_RTL_SECONDS=5
GPS_LOSS_LAND_SECONDS=10
REMOTE_ID_ENABLED=False
REMOTE_ID_BROADCAST_METHOD=mavlink
REMOTE_ID_OPERATOR_ID=
REMOTE_ID_SERIAL_NUMBER=
REMOTE_ID_DESCRIPTION=
PART107_NIGHT_AUTHORIZED=False
PART107_BVLOS_AUTHORIZED=False
PART107_WAIVER_NOTES=
MOTOR_TEST_DURATION_SECONDS=2

# Application Configuration
ENVIRONMENT=production
LOG_LEVEL=INFO
