# MAVLink Connection Configuration
MAVLINK_CONNECTION_TYPE=serial
MAVLINK_PORT=/dev/serial0
MAVLINK_BAUDRATE=57600
MAVLINK_TIMEOUT=30

# For UDP SITL on the same Pi:
# MAVLINK_CONNECTION_TYPE=udp
# MAVLINK_UDP_DIRECTION=in
# MAVLINK_UDP_IP=0.0.0.0
# MAVLINK_UDP_PORT=5760

# For remote SITL on another host:
# MAVLINK_CONNECTION_TYPE=udp
# MAVLINK_UDP_DIRECTION=out
# MAVLINK_UDP_IP=192.168.1.40
# MAVLINK_UDP_PORT=5760

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=False
API_AUTH_ENABLED=True
API_KEY=replace-with-a-long-random-token
SAFETY_GATES_ENABLED=True
COMMAND_AUTHORITY_ENABLED=True
COMMAND_AUTHORITY_LEASE_SECONDS=30
TELEMETRY_FRESHNESS_ENABLED=True
TELEMETRY_STALE_SECONDS=3
PAYLOAD_STALE_SECONDS=3
AUDIT_LOG_FILE=/var/lib/drone-companion/audit/events.jsonl
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Payload Hardware Pins (GPIO)
SPRAY_PUMP_PIN=17
CAMERA_ENABLED=True
CAMERA_PORT=0
CAMERA_TRIGGER_ENABLED=False
CAMERA_TRIGGER_PIN=22
CAMERA_TRIGGER_PULSE_MS=100
APP_DATA_DIRECTORY=/var/lib/drone-companion
PHOTO_DIRECTORY=/var/lib/drone-companion/photos
SPRAY_SESSION_DIRECTORY=/var/lib/drone-companion/spray-sessions
MISSION_FILE=/var/lib/drone-companion/missions/mission.json
FLOW_SENSOR_PIN=27
FLOW_SENSOR_ENABLED=True
FLOW_SENSOR_PULSES_PER_LITER=450

# Pressure sensor: SOURCE=adc for MCP3008-style ADC, or gpio for threshold switch
PRESSURE_SENSOR_ENABLED=False
PRESSURE_SENSOR_SOURCE=adc
PRESSURE_SENSOR_PIN=
PRESSURE_SENSOR_ADC_CHANNEL=0
PRESSURE_SENSOR_MIN_VOLTAGE=0.5
PRESSURE_SENSOR_MAX_VOLTAGE=4.5
PRESSURE_SENSOR_MIN_PSI=0
PRESSURE_SENSOR_MAX_PSI=150

# Tank level sensor: SOURCE=adc for level sender, or gpio for low-level switch
TANK_LEVEL_SENSOR_ENABLED=False
TANK_LEVEL_SENSOR_SOURCE=adc
TANK_LEVEL_SENSOR_PIN=
TANK_LEVEL_SENSOR_ADC_CHANNEL=1
TANK_LEVEL_SENSOR_MIN_VOLTAGE=0.5
TANK_LEVEL_SENSOR_MAX_VOLTAGE=4.5
TANK_CAPACITY_LITERS=10
TANK_MIN_LEVEL_PERCENT=10

# RTK/PPK configuration. These typically use Pixhawk/GNSS serial links, not GPIO.
RTK_ENABLED=False
RTK_CORRECTION_PORT=/dev/ttyUSB0
RTK_CORRECTION_BAUDRATE=115200
PPK_ENABLED=False
PPK_LOG_DIRECTORY=/var/lib/drone-companion/ppk
SPRAY_APPLICATION_RECORD_DIRECTORY=/var/lib/drone-companion/application-records

# Terrain following uses Pixhawk rangefinder/terrain data when available.
TERRAIN_FOLLOWING_ENABLED=False
TERRAIN_SENSOR_SOURCE=rangefinder
TERRAIN_SENSOR_PIN=
TERRAIN_MIN_AGL_METERS=2
TERRAIN_MAX_AGL_METERS=120
TERRAIN_TARGET_AGL_METERS=
TERRAIN_USE_RANGEFINDER_FOR_WAYPOINTS=True
TERRAIN_RTL_ENABLED=False
TERRAIN_SPACING_METERS=

# Mission Configuration
MAX_WAYPOINTS=100
MIN_ALTITUDE=5
MAX_ALTITUDE=120
DEFAULT_AIRSPEED=5
LOITER_RADIUS=50

# Obstacle avoidance delegates to ArduPilot's configured proximity/rangefinder sensors.
# Modes: simple, bendy_ruler, disabled
OBSTACLE_AVOIDANCE_ENABLED=False
OBSTACLE_AVOIDANCE_MODE=simple
OBSTACLE_AVOIDANCE_MARGIN_METERS=2
OBSTACLE_AVOIDANCE_LOOKAHEAD_METERS=5
OBSTACLE_AVOIDANCE_BACKUP_SPEED_MPS=0
OBSTACLE_AVOIDANCE_MIN_ALTITUDE_METERS=0
OBSTACLE_AVOIDANCE_PROXIMITY_TYPE=4
OBSTACLE_AVOIDANCE_BEHAVIOR=slide
OBSTACLE_AVOIDANCE_BENDY_RULER_TYPE=horizontal
OBSTACLE_DATABASE_SIZE=

# Telemetry Configuration
TELEMETRY_UPDATE_INTERVAL=0.5
TELEMETRY_HISTORY_SIZE=3600
GPS_TIMEOUT=10

# Application Configuration
ENVIRONMENT=production
LOG_LEVEL=INFO
